<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list -->
    <record id="doctor_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.list</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="full_name"/>
                <field name="category_id"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="show"/>
                <field name="is_intern"/>
                <button name="action_archive"
                        type="object"
                        icon="fa-archive"
                        string="Archive"
                        invisible="not active"/>
                <button name="action_unarchive"
                        type="object"
                        icon="oi-unarchive"
                        string="Unarchive"
                        invisible="active"/>
            </list>
        </field>
    </record>

    <!-- form -->
    <record id="doctor_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.form</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_128'}"/>
                    <group>
                        <group>
                            <separator string="Doctor Information"/>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="middle_name"/>
                            <field name="category_id"/>
                            <field name="mentor_id"
                                   readonly="not is_intern"
                                   domain="[('is_intern', '=', False), ('id', '!=', id)]"/>
                        </group>
                        <group>
                            <separator string="Contact Information"/>
                            <field name="email_state" invisible="True"/>
                            <field name="phone_state" invisible="True"/>
                            <field name="email" string="Email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Interns" invisible="is_intern or not intern_ids">
                            <field name="intern_ids">
                                <kanban quick_create="false" group_create="false">
                                    <field name="id"/>
                                    <field name="full_name"/>
                                    <field name="category_id"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click">
                                                <div class="oe_kanban_details">
                                                    <strong>
                                                        <field name="full_name"/>
                                                    </strong>
                                                    <div>
                                                        <div class="mt-2">
                                                            <strong>Age: </strong>
                                                            <field name="age"/>
                                                        </div>
                                                        <div>
                                                            <i class="fa fa-phone-square me-2"
                                                               title="Phone"/>
                                                            <field name="phone"/>
                                                        </div>
                                                        <div>
                                                            <i class="fa fa-envelope me-2"
                                                               title="Email"/>
                                                            <field name="email"/>
                                                        </div>
                                                        <div>
                                                            <strong>Gender: </strong>
                                                            <field name="gender"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- search -->
    <record id="doctor_view_search" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.search</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <search>
                <field name="full_name"
                       string="Doctor or Phone"
                       filter_domain="[
                            '|',
                            ('full_name', 'ilike', self),
                            ('phone', 'ilike', self)
                       ]"/>
                <filter name="filter_mentors"
                        string="Mentors"
                        domain="[('intern_ids', '!=', False)]"/>
                <filter name="filter_interns"
                        string="Interns"
                        domain="[('is_intern', '=', True)]"/>
                <filter name="filter_archived"
                        string="Archived"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- kanban -->
    <record id="doctor_view_kanban" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.kanban</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban highlight_color="color"
                    class="o_kanban_small_column o_opportunity_kanban"
                    sample="1"
                    default_group_by="category_id"
                    quick_create="False"
                    group_create="False"
                    archivable="false">
                <field name="id"/>
                <field name="full_name"/>
                <field name="category_id"/>
                <field name="intern_ids"/>

                <templates>
                    <t t-name="menu">
                        <t t-if="widget.editable"><a role="menuitem" type="open" class="dropdown-item">Edit</a></t>
                        <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                        <div role="separator" class="dropdown-divider"/>
                        <field name="color" widget="kanban_color_picker"/>
                    </t>
                    <t t-name="card">
                        <div>
                            <strong class="o_kanban_record_title">
                                <field name="full_name"/>
                            </strong>
                            <div class="o_kanban_record_subtitle">
                                <field name="category_id"/>
                            </div>
                            <div>
                                <field name="intern_ids" widget="many2many_tags"/>
                            </div>
                            <div>
                                <button name="action_quick_create_visit"
                                        type="object"
                                        class="btn btn-primary mt-3">
                                    New Visit
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- action -->
    <record id="doctor_action" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hr_hospital.doctor</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">
            {
                'search_default_group_by_category_id': 1
            }
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor!
            </p>
        </field>
    </record>

    <!-- menu -->
    <menuitem id="doctor_menu"
              name="Doctors"
              parent="hr_hospital.hr_hospital_menu_references"
              sequence="10"/>

    <menuitem id="doctor_all_menu"
              name="Doctors"
              parent="doctor_menu"
              action="doctor_action" sequence="10"/>

</odoo>