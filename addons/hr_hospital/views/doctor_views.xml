<odoo>
    <record id="doctor_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.list</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="specialty"/>
            </list>
        </field>
    </record>

    <record id="doctor_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.form</field>
        <field name="model">hr_hospital.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <separator string="Doctor Information"/>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <group>
                            <field name="specialty"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="doctor_action" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hr_hospital.doctor</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor!
            </p>
        </field>
    </record>

    <menuitem id="doctor_menu"
          name="👨‍⚕️ Doctors"
          parent="hr_hospital_menu_references"
          action="doctor_action"
          sequence="10"/>

</odoo>