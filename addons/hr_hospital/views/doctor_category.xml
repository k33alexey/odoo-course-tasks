<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="doctor_category_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.category.list</field>
        <field name="model">hr_hospital.doctor.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="doctor_category_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.category.form</field>
        <field name="model">hr_hospital.doctor.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="doctor_category_action" model="ir.actions.act_window">
        <field name="name">Doctor Category</field>
        <field name="res_model">hr_hospital.doctor.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor category!
            </p>
        </field>
    </record>

    <menuitem id="doctor_category_menu"
              name="Categories"
              parent="hr_hospital.doctor_menu"
              action="doctor_category_action" sequence="20"/>
</odoo>