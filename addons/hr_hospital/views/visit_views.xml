<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list -->
    <record id="visit_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.visit.list</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name" string="Number"/>
                <field name="visit_date"/>
                <field name="doctor_id"/>
                <field name="patient_id"/>
                <field name="disease_id"/>
                <button name="action_archive"
                        type="object"
                        icon="fa-archive"
                        string="Archive"
                        invisible="not active"/>
                <button name="action_unarchive"
                        type="object"
                        icon="oi-unarchive"
                        string="Unarchive"
                        invisible="active"/>
            </list>
        </field>
    </record>

    <!-- form -->
    <record id="visit_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.visit.form</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': False}"/>
                    <button name="action_view_visits_by_disease"
                            string="Patient visits by disease"
                            type="object"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <field name="state" widget="badge" decoration-success="state == 'done'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Planning">
                            <field name="visit_date"/>
                            <field name="doctor_id" options="{'no_create': True}"/>
                        </group>
                        <group string="Patient Info">
                            <field name="patient_id" options="{'no_quick_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Medical Details" name="details">
                            <separator string="Diagnosis"/>
                            <field name="disease_id"/>
                            <separator string="Doctor Notes"/>
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- calendar -->
    <record id="visit_view_calendar" model="ir.ui.view">
        <field name="name">hr.hospital.visit.calendar</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <calendar string="Visits"
                      date_start="visit_date"
                      color="doctor_id"
                      mode="month">
                <field name="patient_id"/>
                <field name="doctor_id" filters="1"/>
                <field name="state" filters="1"/>
            </calendar>
        </field>
    </record>

    <!-- pivot -->
    <record id="visit_view_pivot" model="ir.ui.view">
        <field name="name">hr.hospital.visit.pivot</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <pivot string="Visit analyse" sample="1">
                <field name="doctor_id" type="row"/>
                <field name="state" type="col"/>
                <field name="visit_date" interval="month" type="row"/>
            </pivot>
        </field>
    </record>

    <!-- graph -->
    <record id="visit_view_graph" model="ir.ui.view">
        <field name="name">hr.hospital.visit.graph</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <graph string="Visits by Month"
                   type="bar"
                   stacked="1">
                <field name="visit_date" interval="month"/>
                <field name="disease_id"/>
            </graph>
        </field>
    </record>

    <!-- search -->
    <record id="visit_view_search" model="ir.ui.view">
        <field name="name">hr.hospital.visit.search</field>
        <field name="model">hr_hospital.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="doctor_id"/>
                <filter string="Current month"
                        name="filter_current_month"
                        domain="[
                            ('visit_date', '&gt;=', context_today().strftime('%Y-%m-01')),
                            ('visit_date', '&lt;', (context_today() + relativedelta(months=1)).strftime('%Y-%m-01'))
                        ]"/>
                <group>
                    <filter string="State" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Doctor" name="group_by_doctor"
                            context="{'group_by': 'doctor_id'}"/>
                    <filter string="State" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Disease" name="group_by_disease"
                            context="{'group_by': 'disease_id'}"/>
                </group>
                <searchpanel>
                    <field name="doctor_id"
                           icon="fa-users"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- action -->
    <record id="visit_action" model="ir.actions.act_window">
        <field name="name">Hospital Visits</field>
        <field name="res_model">hr_hospital.visit</field>
        <field name="view_mode">list,form,calendar,pivot,graph</field>
        <field name="context">{'default_name': 'New'}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first hospital visit!
            </p>
        </field>
    </record>

    <!-- menu -->
    <menuitem id="visit_menu"
              name="Visits"
              parent="hr_hospital_menu_documents"
              action="visit_action"
              sequence="10"/>

</odoo>