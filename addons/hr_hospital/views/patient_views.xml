<odoo>
    <record id="patient_view_tree" model="ir.ui.view">
        <field name="name">hr.hospital.patient.list</field>
        <field name="model">hr_hospital.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="birth_date"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="patient_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.patient.form</field>
        <field name="model">hr_hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <separator string="Patient Information"/>
                    <group>
                        <field name="name"/>
                        <field name="birth_date"/>
                        <field name="gender" widget="radio" options="{'horizontal': True}"/>
                    </group>
                    <separator string="Visit History"/>
                    <field name="visit_ids">
                        <list>
                            <field name="visit_date"/>
                            <field name="doctor_id"/>
                            <field name="disease_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="patient_action" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hr_hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="patient_menu" model="ir.ui.menu">
        <field name="name">Patients</field>
        <field name="parent_id" ref="hr_hospital_menu_references"/>
        <field name="action" ref="patient_action"/>
        <field name="sequence">20</field>
    </record>

</odoo>