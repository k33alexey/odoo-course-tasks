<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- hierarchy panel -->
    <record id="disease_view_hierarchy_search" model="ir.ui.view">
        <field name="name">hr_hospital.disease.search</field>
        <field name="model">hr_hospital.disease</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <searchpanel>
                    <field name="parent_id"
                           icon="fa-filter"
                           hierarchize="0"
                           enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- list -->
    <record id="disease_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.disease.list</field>
        <field name="model">hr_hospital.disease</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <!-- form -->
    <record id="disease_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.disease.form</field>
        <field name="model">hr_hospital.disease</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="color"/>
                        <field name="parent_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action -->
    <record id="disease_action" model="ir.actions.act_window">
        <field name="name">Diseases</field>
        <field name="res_model">hr_hospital.disease</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first disease!
            </p>
        </field>
    </record>

    <!-- menu -->
    <menuitem id="disease_menu"
              name="Diseases"
              parent="hr_hospital.doctor_menu"
              action="disease_action" sequence="30"/>
</odoo>