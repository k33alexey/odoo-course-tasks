<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="doctor_history_view_list" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.history.list</field>
        <field name="model">hr_hospital.doctor.history</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="assigned_date"/>
                <field name="shift_date"/>
                <field name="doctor_id"/>
                <field name="patient_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="doctor_history_view_form" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.history.form</field>
        <field name="model">hr_hospital.doctor.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="assigned_date"/>
                        <field name="shift_date"/>
                        <field name="doctor_id"/>
                        <field name="patient_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="doctor_history_action" model="ir.actions.act_window">
        <field name="name">Doctor History</field>
        <field name="res_model">hr_hospital.doctor.history</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor history!
            </p>
        </field>
    </record>

    <menuitem id="doctor_history_menu"
              name="History"
              parent="hr_hospital.doctor_menu"
              action="doctor_history_action" sequence="30"/>
</odoo>