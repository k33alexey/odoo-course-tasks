<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="visit_report_wizard_form" model="ir.ui.view">
        <field name="name">hr.hospital.visit.report.wizard.form</field>
        <field name="model">hr_hospital.visit.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generating a visit report">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="only_done"/>
                </group>
                <group>
                    <field name="doctor_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="patient_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="disease_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_generate_report" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="visit_report_wizard_doctor_action" model="ir.actions.act_window">
        <field name="name">Visit report</field>
        <field name="res_model">hr_hospital.visit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_doctor"/>
        <field name="binding_view_types">list,form</field>
        <field name="binding_type">report</field>
    </record>

    <record id="visit_report_wizard_patient_action" model="ir.actions.act_window">
        <field name="name">Visit report</field>
        <field name="res_model">hr_hospital.visit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_patient"/>
        <field name="binding_view_types">list,form</field>
        <field name="binding_type">report</field>
    </record>
</odoo>