<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mass_reassign_doctor_wizard_form" model="ir.ui.view">
        <field name="name">hr.hospital.mass.reassign.doctor.wizard.form</field>
        <field name="model">hr_hospital.mass.reassign.doctor.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="doctor_id"/>
                    <field name="reassign_date"/>
                </group>
                <footer>
                    <button name="action_reassign" string="Reassign" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="mass_reassign_doctor_action" model="ir.actions.act_window">
        <field name="name">Massive doctor reassign</field>
        <field name="res_model">hr_hospital.mass.reassign.doctor.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_hr_hospital_patient"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>