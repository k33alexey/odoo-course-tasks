<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"/>

    <!-- hospital category -->
    <record id="category_hr_hospital" model="ir.module.category">
        <field name="name">Hospital</field>
        <field name="description">User access levels for the Hospital</field>
        <field name="sequence">1</field>
    </record>

    <!-- group patient -->
    <record id="group_hr_hospital_patient" model="res.groups">
        <field name="name">Patient</field>
        <field name="category_id" ref="category_hr_hospital"/>
        <field name="comment">Patients of the Hospital</field>
    </record>

    <!-- group intern -->
    <record id="group_hr_hospital_intern" model="res.groups">
        <field name="name">Intern</field>
        <field name="category_id" ref="category_hr_hospital"/>
        <field name="implied_ids" eval="[Command.link(ref('group_hr_hospital_patient'))]"/>
        <field name="comment">Interns of the Hospital</field>
    </record>

    <!-- group doctor -->
    <record id="group_hr_hospital_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="category_id" ref="category_hr_hospital"/>
        <field name="implied_ids" eval="[Command.link(ref('group_hr_hospital_intern'))]"/>
        <field name="comment">Doctors of the Hospital</field>
    </record>

    <!-- group manager -->
    <record id="group_hr_hospital_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="category_hr_hospital"/>
        <field name="implied_ids" eval="[Command.link(ref('group_hr_hospital_doctor'))]"/>
        <field name="comment">Managers of the Hospital</field>
    </record>

    <!-- group admin -->
    <record id="group_hr_hospital_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="category_hr_hospital"/>
        <field name="implied_ids" eval="[Command.link(ref('group_hr_hospital_manager'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        <field name="comment">Administrators of the Hospital (full rights)</field>
    </record>
</odoo>