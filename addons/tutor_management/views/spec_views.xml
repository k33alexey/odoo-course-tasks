<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list -->
    <record id="tutor_spec_view_list" model="ir.ui.view">
        <field name="name">tutor.spec.list</field>
        <field name="model">tutor.specialization</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="price"/>
            </list>
        </field>
    </record>

    <!-- form -->
    <record id="tutor_spec_view_form" model="ir.ui.view">
        <field name="name">tutor.spec.form</field>
        <field name="model">tutor.specialization</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="currency_id" invisible="True"/>
                        <field name="price"/>
                    </group>
                    <notebook>
                        <page string="Tutors">
                            <field name="tutor_ids" readonly="True">
                                <list>
                                    <field name="full_name"/>
                                    <field name="age"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action -->
    <record id="tutor_spec_view_action" model="ir.actions.act_window">
        <field name="name">Tutor Specialization</field>
        <field name="res_model">tutor.specialization</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first specialization!
            </p>
        </field>
    </record>

</odoo>