<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list -->
    <record id="lesson_view_list" model="ir.ui.view">
        <field name="name">tutor.lesson.list</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="name" string="Number"/>
                <field name="appointment_date"/>
                <field name="spec_id"/>
                <field name="tutor_id"/>
                <field name="student_id"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="price"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'planned'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancel'"/>
                <button name="action_archive"
                        type="object"
                        icon="fa-archive"
                        string="Archive"
                        invisible="not active"/>
                <button name="action_unarchive"
                        type="object"
                        icon="oi-unarchive"
                        string="Unarchive"
                        invisible="active"/>
            </list>
        </field>
    </record>

    <!-- form -->
    <record id="lesson_view_form" model="ir.ui.view">
        <field name="name">tutor.lesson.form</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_in_progress" type="object" string="Start Lesson"
                            class="oe_highlight" invisible="state != 'planned'"/>
                    <button name="action_done" type="object" string="Mark as Done"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state not in ['planned', 'in_progress']"/>
                    <button name="action_draft" type="object" string="Set to Planned"
                            invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planned,in_progress,done"
                           options="{'clickable': False}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Done" bg_color="text-bg-success"
                            invisible="state != 'done'"/>
                    <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger"
                            invisible="state != 'cancel'"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lessons_by_spec"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="count_by_spec"/></span>
                                <span class="o_stat_text">
                                    Lessons for <field name="tutor_id" readonly="True"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group string="Planning">
                        <field name="appointment_date"/>
                        <field name="tutor_id" options="{'no_create': True}"/>
                        <field name="allowed_spec_ids" invisible="True"/>
                        <field name="spec_id"
                               domain="[('id', 'in', allowed_spec_ids)]"
                               options="{'no_create': True}"/>
                        <field name="currency_id" invisible="True"/>
                        <field name="price"/>
                    </group>
                    <group string="Student Info">
                        <field name="student_id" options="{'no_quick_create': True}"/>
                    </group>
                    <separator string="Tutor Notes"/>
                    <field name="notes" readonly="state in ['done', 'cancel']"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- kanban -->
    <record id="lesson_view_kanban" model="ir.ui.view">
        <field name="name">tutor.lesson.kanban</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false" sample="1">
                <field name="state"/>
                <field name="appointment_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes':
                                            {
                                                'planned': 'secondary',
                                                'in_progress': 'warning',
                                                'done': 'success',
                                                'cancel': 'danger'
                                            }
                                       }"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-calendar me-1"/> <field name="appointment_date"/></div>
                                <div><i class="fa fa-user me-1"/> <field name="tutor_id"/></div>
                                <div><i class="fa fa-graduation-cap me-1"/> <field name="student_id"/></div>
                                <div><i class="fa fa-book me-1"/> <field name="spec_id"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- search -->
    <record id="lesson_view_search" model="ir.ui.view">
        <field name="name">tutor.lesson.search</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <search>
                <field name="tutor_id"/>
                <filter string="Date" name="filter_lesson_month" date="appointment_date" default_period="month"/>
                <group>
                    <filter string="State" name="group_by_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Tutor" name="group_by_tutor"
                            context="{'group_by': 'tutor_id'}"/>
                    <filter string="Specialization" name="group_by_spec"
                            context="{'group_by': 'spec_id'}"/>
                </group>
                <searchpanel>
                    <field name="tutor_id"
                           icon="fa-users"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- calendar -->
    <record id="lesson_view_calendar" model="ir.ui.view">
        <field name="name">tutor.lesson.calendar</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <calendar string="Lessons"
                      date_start="appointment_date"
                      color="tutor_id"
                      mode="month">
                <field name="student_id"/>
                <field name="tutor_id" filters="1"/>
                <field name="state" filters="1"/>
            </calendar>
        </field>
    </record>

    <!-- pivot -->
    <record id="lesson_view_pivot" model="ir.ui.view">
        <field name="name">tutor.lesson.pivot</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <pivot string="Lesson Analysis" sample="1">
                <field name="tutor_id" type="row"/>
                <field name="state" type="col"/>
                <field name="appointment_date" interval="month" type="row"/>
            </pivot>
        </field>
    </record>

    <!-- graph -->
    <record id="lesson_view_graph" model="ir.ui.view">
        <field name="name">tutor.lesson.graph</field>
        <field name="model">tutor.lesson</field>
        <field name="arch" type="xml">
            <graph string="Lessons Revenue by Specialization"
                   type="pie"
                   sample="1">
                <field name="spec_id"/>
                <field name="price" string="Total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- action -->
    <record id="lesson_action" model="ir.actions.act_window">
        <field name="name">Lessons</field>
        <field name="res_model">tutor.lesson</field>
        <field name="view_mode">list,form,kanban,calendar,pivot,graph</field>
        <field name="context">{'default_name': 'New'}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first lesson!
            </p>
        </field>
    </record>

</odoo>

