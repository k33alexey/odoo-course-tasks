<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1"/>

    <!-- rule student -->
    <record id="tutor_rule_student" model="ir.rule">
        <field name="name">Students can only view own lessons</field>
        <field name="model_id" ref="model_tutor_lesson"/>
        <field name="domain_force">[('student_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('group_tutor_student'))]"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_unlink" eval="False"/>
        <field name="perm_write" eval="False"/>
    </record>

    <!-- rule tutor -->
    <record id="tutor_rule_tutor" model="ir.rule">
        <field name="name">Tutors can only view own lessons</field>
        <field name="model_id" ref="model_tutor_lesson"/>
        <field name="domain_force">[('tutor_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('group_tutor_tutor'))]"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_unlink" eval="False"/>
        <field name="perm_write" eval="True"/>
    </record>

    <!-- rule admin -->
    <record id="tutor_rule_admin" model="ir.rule">
        <field name="name">Administrator can view all of lessons</field>
        <field name="model_id" ref="model_tutor_lesson"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('group_tutor_admin'))]"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="perm_write" eval="True"/>
    </record>

</odoo>